<?xml version="1.0" encoding="utf-8"?>
<manifest xmlns:android="http://schemas.android.com/apk/res/android">

    <application>
        <!-- Main navigation activity -->
        <activity
            android:name=".MainActivity"
            android:exported="true"
            android:label="@string/app_name"
            android:theme="@style/Theme.Material3.DayNight.NoActionBar">
            <intent-filter>
                <action android:name="android.intent.action.MAIN" />
                <category android:name="android.intent.category.LAUNCHER" />
            </intent-filter>
        </activity>

        <!-- Same direction conflict scene -->
        <activity
            android:name=".scenes.SameDirectionActivity"
            android:exported="false"
            android:label="@string/scene_same_direction_title"
            android:parentActivityName=".MainActivity"
            android:theme="@style/Theme.Material3.DayNight.NoActionBar" />

        <!-- Opposite direction conflict scene -->
        <activity
            android:name=".scenes.OppositeDirectionActivity"
            android:exported="false"
            android:label="@string/scene_opposite_direction_title"
            android:parentActivityName=".MainActivity"
            android:theme="@style/Theme.Material3.DayNight.NoActionBar" />

        <!-- Mixed conflict scene -->
        <activity
            android:name=".scenes.MixedConflictActivity"
            android:exported="false"
            android:label="@string/scene_mixed_conflict_title"
            android:parentActivityName=".MainActivity"
            android:theme="@style/Theme.Material3.DayNight.NoActionBar" />
    </application>

</manifest>
