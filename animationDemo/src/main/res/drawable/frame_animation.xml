<?xml version="1.0" encoding="utf-8"?>
<!--
    帧动画（Frame Animation）：像翻书一样，逐帧切换 drawable
    每帧显示 300ms，oneshot=false 表示循环播放
-->
<animation-list xmlns:android="http://schemas.android.com/apk/res/android"
    android:oneshot="false">
    <item android:drawable="@drawable/shape_circle_red" android:duration="300" />
    <item android:drawable="@drawable/shape_circle_blue" android:duration="300" />
    <item android:drawable="@drawable/shape_circle_green" android:duration="300" />
    <item android:drawable="@drawable/shape_circle_yellow" android:duration="300" />
</animation-list>
