<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:padding="16dp"
    android:gravity="center_horizontal">

    <TextView
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="转场动画（Activity Transition）\n\n• overridePendingTransition：最基础的 Activity 切换动画\n• 共享元素动画：两个页面共享同一个元素的过渡效果"
        android:textSize="14sp"
        android:layout_marginBottom="16dp" />

    <!-- 共享元素 -->
    <View
        android:id="@+id/sharedElement"
        android:layout_width="100dp"
        android:layout_height="100dp"
        android:background="@drawable/shape_target_box"
        android:transitionName="shared_box"
        android:layout_marginBottom="24dp" />

    <Button android:id="@+id/btnSlide" android:layout_width="match_parent" android:layout_height="wrap_content"
        android:text="滑动转场（overridePendingTransition）" />

    <Button android:id="@+id/btnSharedElement" android:layout_width="match_parent" android:layout_height="wrap_content"
        android:text="共享元素转场" />

</LinearLayout>
